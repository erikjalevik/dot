{
  // --- Built-ins ---
  "debug.console.closeOnEnd": true,
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.accessibilitySupport": "off",
  "editor.autoClosingQuotes": "never",
  "editor.fontSize": 11,
  "editor.fontFamily": "'Monaspace Neon', Menlo, Monaco, 'Courier New', monospace",
  "editor.fontLigatures": "'calt', 'liga', 'dlig', 'ss01', 'ss02', 'ss03', 'ss04', 'ss06'",
  "editor.inlineSuggest.suppressSuggestions": true,
  "editor.minimap.enabled": false,
  "editor.tabCompletion": "on",
  "editor.tabSize": 2,
  "editor.renderWhitespace": "all",
  "editor.detectIndentation": false,
  "editor.snippetSuggestions": "top",
  "editor.stickyScroll.enabled": false,
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "editor.wordBasedSuggestions": "off",
  "explorer.autoReveal": false,
  "explorer.confirmPasteNative": false,
  "explorer.openEditors.visible": 22, // height of editors pane before scrolling
  "extensions.ignoreRecommendations": true,
  "files.associations": {
    "*.talon": "python",
    "*.talon-list": "python",
    "*.mdx": "markdown"
  },
  "terminal.integrated.lineHeight": 1.5,
  "terminal.integrated.defaultLocation": "editor",
  "window.title": "${activeEditorMedium}${separator}${rootName}",
  "workbench.colorTheme": "Dark Modern",
  "workbench.editor.customLabels.patterns": {
    // Show Sveltekit +page etc files with their parent dir
    "**/*+*.*": "${dirname}/${filename}.${extname}"
  },
  "workbench.editor.showTabs": "single",
  "workbench.editor.labelFormat": "medium",
  "workbench.editor.enablePreviewFromQuickOpen": false,
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 10, // max number of open editors
  "workbench.editor.limit.perEditorGroup": true, // make max apply per group
  // --- Extensions ---
  "bookmarks.navigateThroughAllFiles": false,
  "claudeCode.preferredLocation": "panel",
  "chat.viewSessions.orientation": "stacked",
  "chat.viewSessions.enabled": false,
  "eslint.format.enable": true,
  "html.autoClosingTags": false,
  "git.blame.editorDecoration.enabled": false,
  "git.openRepositoryInParentFolders": "never",
  "github.copilot.nextEditSuggestions.eagerness": "high",
  "github.copilot.nextEditSuggestions.extendedRange": true,
  "js/ts.autoClosingTags.enabled": false,
  "js/ts.preferences.preferTypeOnlyAutoImports": true,
  "js/ts.preferences.renameMatchingJsxTags": true,
  "js/ts.preferences.useAliasesForRenames": false,
  "json.format.keepLines": true,
  "markdown.preview.breaks": true,
  "svelte.enable-ts-plugin": true,
  "svelte.plugin.svelte.defaultScriptLanguage": "ts",
  "[markdown]": {
    // Needed for snippets to work in markdown
    "editor.quickSuggestions": {
      "other": true,
      "comments": true,
      "strings": true
    },
    "editor.wordWrap": "on"
  },
  "[plaintext]": {
    "editor.wordWrap": "on"
  },
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[css]": {
    "editor.defaultFormatter": "vscode.css-language-features"
  },
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
  },
  "[svelte]": {
    "editor.defaultFormatter": "svelte.svelte-vscode"
  },
  "workbench.editorAssociations": {
    "*.copilotmd": "vscode.markdown.preview.editor",
    "{hexdiff}:/**/*.*": "hexEditor.hexedit",
    "*.svg": "default"
  }
}
